<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <!-- Override LOG_DIR in a pod to point at a mounted volume. -->
        <Property name="LOG_DIR">${env:LOG_DIR:-logs}</Property>
        <Property name="PATTERN">%d{ISO8601} %-5level [%t] %logger{36} - %msg%n</Property>
    </Properties>

    <Appenders>
        <!-- Console: captured by the pod's stdout/log driver. -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${PATTERN}"/>
        </Console>

        <!-- Rolling file: persistent local logs; rolls daily or at 10 MB, keeps 10 archives gzipped. -->
        <RollingFile name="RollingFile"
                     fileName="${LOG_DIR}/coduel.log"
                     filePattern="${LOG_DIR}/coduel-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="10"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="com.coduel" level="DEBUG"/>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
    </Loggers>
</Configuration>
